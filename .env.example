BOT_TOKEN=your_telegram_bot_token
API_ID=your_telegram_api_id
API_HASH=your_telegram_api_hash
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_or_anon_key
# Tavsiya (production): service_role kalit — serverda SUPABASE_SERVICE_KEY
SUPABASE_SERVICE_KEY=
GEMINI_API_KEY=your_gemini_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
CARGO_GROUPS=-1002468475563,-1002956624079,-1002182000321
# Rasmiy Karvon guruh — bot moderatsiya + broker post (admin huquqi kerak)
ROYAL_CARGO_GROUP_ID=-1001234567890
# Broker yuklari avtomat tushadigan lichkalar (Telegram user ID, vergul bilan)
CROSSPOST_DM_ID=7736700647,2034477138
# Server (DigitalOcean) uchun — session.txt dan nusxa (lokalda login qilib oling)
# DO da kalit: TELEGRAM_SESSION (butun qator, ~369 belgi)
# YOKI: TELEGRAM_SESSION_B64 (node scripts/print-session-for-do.js --b64)
# MUHIM: session.txt ni TELEGRAM_SESSION_B64 ga to'g'ridan QO'YMASLIK!
TELEGRAM_SESSION=
# Tarmoq muammosi bo'lsa: TELEGRAM_USE_WSS=1
TELEGRAM_USE_WSS=0
